<UserControl x:Class="ImageWatch.ToolWindow.ImageWatchToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ImageWatch.Controls"
             Background="#1E1E1E">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="220" MinWidth="120"/>
      <ColumnDefinition Width="5"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ── Left panel ───────────────────────────────────────────────── -->
    <DockPanel Grid.Column="0" Background="#252526">

      <!-- Group header: 局部变量 / 监视 -->
      <Border DockPanel.Dock="Top" Background="#1E1E1E" BorderBrush="#3F3F46"
              BorderThickness="0,0,0,1" Padding="6,4">
        <DockPanel>
          <TextBlock Text="帮助" DockPanel.Dock="Right"
                     Foreground="#569CD6" FontSize="11" Cursor="Hand" VerticalAlignment="Center"/>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <RadioButton GroupName="ViewGroup" IsChecked="True"
                         Foreground="#D4D4D4" FontSize="11" Margin="0,0,12,0"
                         VerticalContentAlignment="Center" Content="局部变量"/>
            <RadioButton GroupName="ViewGroup"
                         Foreground="#D4D4D4" FontSize="11"
                         VerticalContentAlignment="Center" Content="监视"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- Variable list -->
      <ListBox ItemsSource="{Binding Variables}"
               SelectedItem="{Binding SelectedVariable, Mode=TwoWay}"
               Background="#252526" Foreground="#D4D4D4"
               BorderThickness="0"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled">
        <ListBox.ItemContainerStyle>
          <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
              <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                  <Border Background="{TemplateBinding Background}" Padding="0">
                    <ContentPresenter/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                      <Setter Property="Background" Value="#3F3F46"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter Property="Background" Value="#2D2D30"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Setter.Value>
            </Setter>
          </Style>
        </ListBox.ItemContainerStyle>

        <ListBox.ItemTemplate>
          <DataTemplate>
            <StackPanel>
              <!-- Header row: toggle + name -->
              <DockPanel Margin="4,4,4,2" LastChildFill="True">
                <ToggleButton DockPanel.Dock="Left"
                              IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                              Width="14" Height="14" Margin="0,0,4,0"
                              Padding="0" Focusable="False"
                              Background="Transparent" BorderThickness="0">
                  <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                      <Setter Property="Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="ToggleButton">
                            <TextBlock x:Name="Arrow" Text="▶"
                                       FontSize="9" Foreground="#999"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <ControlTemplate.Triggers>
                              <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                              </Trigger>
                            </ControlTemplate.Triggers>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </Style>
                  </ToggleButton.Style>
                </ToggleButton>
                <TextBlock Text="{Binding Name}"
                           Foreground="#D4D4D4" FontSize="12"
                           VerticalAlignment="Center"/>
              </DockPanel>

              <!-- Expanded content: thumbnail + info -->
              <Grid Margin="22,0,4,6">
                <Grid.Style>
                  <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                        <Setter Property="Visibility" Value="Visible"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="60"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Thumbnail -->
                <Grid Grid.Column="0" Width="56" Height="42" Margin="0,0,6,0"
                      Background="#3F3F46">
                  <!-- Placeholder when no thumbnail -->
                  <TextBlock Text="[无效]" Foreground="#777"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" FontSize="9">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding ThumbnailImage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Visible"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                  <Image Source="{Binding ThumbnailImage}" Stretch="Uniform"
                         RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </Grid>

                <!-- Info text -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="{Binding SizeText}"    FontSize="11" Foreground="#D4D4D4"/>
                  <TextBlock Text="{Binding TypeInfoText}" FontSize="11" Foreground="#D4D4D4"/>
                  <TextBlock Text="cv::Mat"               FontSize="11" Foreground="#888"/>
                </StackPanel>
              </Grid>
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </DockPanel>

    <!-- Splitter -->
    <GridSplitter Grid.Column="1" Width="5"
                  HorizontalAlignment="Stretch"
                  Background="#3F3F46"
                  ResizeBehavior="PreviousAndNext"/>

    <!-- ── Right panel ──────────────────────────────────────────────── -->
    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Info bar: cursor coords + zoom -->
      <Border Grid.Row="0" Background="#2D2D30"
              BorderBrush="#3F3F46" BorderThickness="0,0,0,1" Padding="6,3">
        <DockPanel>
          <TextBlock Text="{Binding ZoomLevelText}"
                     DockPanel.Dock="Right"
                     Foreground="#9CDCFE" FontSize="11" FontFamily="Consolas"
                     Margin="8,0,2,0" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding CursorInfoText}"
                     Foreground="#D4D4D4" FontSize="11" FontFamily="Consolas"
                     VerticalAlignment="Center"/>
        </DockPanel>
      </Border>

      <!-- Image canvas -->
      <controls:ZoomableImageCanvas Grid.Row="1" x:Name="ImageCanvas"
                                    ImageSource="{Binding CurrentImage}"
                                    RawData="{Binding CurrentRawData}"
                                    MatInfo="{Binding CurrentMatInfo}"/>

      <!-- Status bar -->
      <Border Grid.Row="2" Background="#007ACC" Padding="6,2">
        <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11"/>
      </Border>
    </Grid>
  </Grid>
</UserControl>
