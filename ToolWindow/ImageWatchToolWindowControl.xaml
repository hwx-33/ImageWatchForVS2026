<UserControl x:Class="ImageWatch.ToolWindow.ImageWatchToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ImageWatch.Controls"
             Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Main area: variable list + image viewer -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220" MinWidth="120"/>
        <ColumnDefinition Width="5"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Variable list -->
      <Border Grid.Column="0" BorderBrush="#444" BorderThickness="0,0,1,0">
        <ListBox ItemsSource="{Binding Variables}"
                 SelectedItem="{Binding SelectedVariable, Mode=TwoWay}"
                 Background="#1E1E1E" Foreground="#D4D4D4"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding DisplayLabel}"
                         Margin="4,2"
                         TextTrimming="CharacterEllipsis"/>
            </DataTemplate>
          </ListBox.ItemTemplate>
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
              <Setter Property="Padding" Value="2"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsStale}" Value="True">
                  <Setter Property="Opacity" Value="0.45"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ListBox.ItemContainerStyle>
        </ListBox>
      </Border>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1" Width="5"
                    HorizontalAlignment="Stretch"
                    Background="#555"
                    ResizeBehavior="PreviousAndNext"/>

      <!-- Image viewer -->
      <controls:ZoomableImageCanvas Grid.Column="2"
                                    ImageSource="{Binding CurrentImage}"
                                    RawData="{Binding CurrentRawData}"
                                    MatInfo="{Binding CurrentMatInfo}"/>
    </Grid>

    <!-- Status bar -->
    <Border Grid.Row="1" Background="#007ACC" Padding="6,2">
      <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11"/>
    </Border>
  </Grid>
</UserControl>
